# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<generate-a-64-char-random-hex>
JWT_REFRESH_SECRET_KEY=<generate-a-different-64-char-random-hex>

# Google OAuth — https://console.cloud.google.com/ → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application)
# Authorized JS origins: http://localhost:5173 (dev), https://yourdomain.com (prod)
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# Database
# Default: SQLite (file in backend folder, no setup needed)
# Production: uncomment and configure PostgreSQL
# DATABASE_URL=postgresql://whatsai:password@db:5432/whats_ai

# ── Azure AI Foundry / Azure OpenAI ───────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
AZURE_OPENAI_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# ── Azure AI Multi-Service ─────────────────────────────────────────────────────
AZURE_MULTISERVICE_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
AZURE_MULTISERVICE_KEY=<your-multiservice-key>
AZURE_MULTISERVICE_REGION=eastus2

# ── Azure Speech ───────────────────────────────────────────────────────────────
AZURE_SPEECH_KEY=<your-speech-key>
AZURE_SPEECH_REGION=eastus2

# ── Gmail SMTP (contact form) ──────────────────────────────────────────────────
SMTP_EMAIL=you@gmail.com
SMTP_APP_PASSWORD=<gmail-app-password>
