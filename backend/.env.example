# ── Azure AI Foundry / Azure OpenAI ───────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
AZURE_OPENAI_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# ── Azure AI Multi-Service ─────────────────────────────────────────────────────
AZURE_MULTISERVICE_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
AZURE_MULTISERVICE_KEY=<your-multiservice-key>
AZURE_MULTISERVICE_REGION=eastus2

# ── Azure Speech ───────────────────────────────────────────────────────────────
AZURE_SPEECH_KEY=<your-speech-key>
AZURE_SPEECH_REGION=eastus2

# ── Gmail SMTP (contact form) ──────────────────────────────────────────────────
SMTP_EMAIL=you@gmail.com
SMTP_APP_PASSWORD=<gmail-app-password>
